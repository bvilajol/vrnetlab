---
- name: Exercice 2
  hosts: routers
  gather_facts: no


  tasks:
    - name: Configure interfaces
      ios_config:
        src: "templates/Cisco_interfaces.j2"
        match: none

    - name: Configure BGP
      ios_config:
        src: "templates/Cisco_bgp.j2"
        match: none
      register: bgp

    - name: Get BGP Facts
      napalm_get_facts:
        filter:
          - "bgp_neighbors"
      register: output

    - debug: var=output
